generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Usuario {
  id         String   @id @default(uuid())
  nome       String
  email      String   @unique
  senha      String
  tipoPerfil String   @map("tipo_perfil")
  avatarUrl  String?  @map("avatar_url")
  criadoEm   DateTime @default(now()) @map("criado_em")

  perfilMentor         PerfilMentor?
  disponibilidades     Disponibilidade[]
  agendamentosMentor   Agendamento[]         @relation("MentorAgendamentos")
  agendamentosAluno    Agendamento[]         @relation("AlunoAgendamentos")
  relatoriosComoMentor RelatorioEntrevista[] @relation("MentorRelatorios")
  relatoriosComoAluno  RelatorioEntrevista[] @relation("AlunoRelatorios")
  avaliacoesAluno      Avaliacao[]           @relation("AlunoAvaliacoes")

  @@map("usuarios")
}

model PerfilMentor {
  id             String   @id @default(uuid())
  usuarioId      String   @unique @map("usuario_id")
  bio            String?
  precoHora      Decimal? @map("preco_hora") @db.Decimal(10, 2)
  especialidades String[]
  githubUrl      String?  @map("github_url")
  linkedinUrl    String?  @map("linkedin_url")

  usuario Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@map("perfis_mentores")
}

model Disponibilidade {
  id             String    @id @default(uuid())
  mentorId       String    @map("mentor_id")
  diaDaSemana    Int?      @map("dia_da_semana")
  dataEspecifica DateTime? @map("data_especifica")
  horaInicio     String    @map("hora_inicio")
  horaFim        String    @map("hora_fim")

  mentor Usuario @relation(fields: [mentorId], references: [id], onDelete: Cascade)

  @@map("disponibilidades")
}

model Agendamento {
  id             String   @id @default(uuid())
  mentorId       String   @map("mentor_id") // <-- Mapeado
  alunoId        String   @map("aluno_id") // <-- Mapeado
  dataHoraInicio DateTime @map("data_hora_inicio") // <-- Mapeado
  vagaAlvo       String   @map("vaga_alvo") // <-- Mapeado
  linkCurriculo  String?  @map("link_curriculo") // <-- Mapeado
  observacoes    String?
  status         String   @default("pendente") // pendente, confirmado, cancelado, concluido
  criadoEm       DateTime @default(now()) @map("criado_em") // <-- Mapeado

  mentor              Usuario              @relation("MentorAgendamentos", fields: [mentorId], references: [id])
  aluno               Usuario              @relation("AlunoAgendamentos", fields: [alunoId], references: [id])
  pagamento           Pagamento?
  relatorioEntrevista RelatorioEntrevista?
  avaliacao           Avaliacao?

  // Impede que um mentor tenha duas sessões no mesmo horário exato
  @@unique([mentorId, dataHoraInicio])
  @@map("agendamentos")
}

model Pagamento {
  id              String   @id @default(uuid())
  agendamentoId   String   @unique @map("agendamento_id")
  valorPago       Decimal  @map("valor_pago") @db.Decimal(10, 2)
  statusPagamento String   @default("aguardando") @map("status_pagamento")
  gatewayId       String?  @map("gateway_id")
  criadoEm        DateTime @default(now()) @map("criado_em")

  agendamento Agendamento @relation(fields: [agendamentoId], references: [id], onDelete: Cascade)

  @@map("pagamentos")
}

model RelatorioEntrevista {
  id               String   @id @default(uuid())
  agendamentoId    String   @unique @map("agendamento_id")
  mentorId         String   @map("mentor_id")
  alunoId          String   @map("aluno_id")
  pontosFortes     String   @map("pontos_fortes")
  pontosMelhoria   String   @map("pontos_melhoria")
  notaTecnica      Int?     @map("nota_tecnica")
  notaSoftSkills   Int?     @map("nota_soft_skills")
  vereditoSimulado String   @map("veredito_simulado")
  criadoEm         DateTime @default(now()) @map("criado_em")

  agendamento Agendamento @relation(fields: [agendamentoId], references: [id], onDelete: Cascade)
  mentor      Usuario     @relation("MentorRelatorios", fields: [mentorId], references: [id])
  aluno       Usuario     @relation("AlunoRelatorios", fields: [alunoId], references: [id])

  @@map("relatorios_entrevista")
}

model Avaliacao {
  id                 String   @id @default(uuid())
  agendamentoId      String   @unique @map("agendamento_id")
  alunoId            String   @map("aluno_id")
  notaAoMentor       Int      @map("nota_ao_mentor")
  feedbackPlataforma String?  @map("feedback_plataforma")
  criadoEm           DateTime @default(now()) @map("criado_em")

  agendamento Agendamento @relation(fields: [agendamentoId], references: [id], onDelete: Cascade)
  aluno       Usuario     @relation("AlunoAvaliacoes", fields: [alunoId], references: [id])

  @@map("avaliacoes")
}
